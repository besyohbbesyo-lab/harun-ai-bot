# ──────────────────────────────────────────────
# Harun AI Bot — Ortam Degiskenleri
# ──────────────────────────────────────────────
# Bu dosyayi .env olarak kopyalayip gercek degerleri girin:
#   copy .env.example .env
#
# .env dosyasi ASLA Git'e pushlenmez (.gitignore'da)
# ──────────────────────────────────────────────

# [ZORUNLU] Telegram Bot Token (@BotFather'dan alinir)
TELEGRAM_TOKEN=

# [ZORUNLU] Groq API Key (groq.com → API Keys)
GROQ_API_KEY=

# [OPSIYONEL] Birden fazla Groq key (virgülle ayir)
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# [ZORUNLU] Izin verilen Telegram kullanici ID'leri (virgülle ayir)
# Telegram'da @userinfobot'a /start yazarak ID'nizi ogrenin
ALLOWED_USER_IDS=

# [OPSIYONEL] Ollama yerel model adresi
# OLLAMA_URL=http://localhost:11434/api/generate

# [OPSIYONEL] RAG sistemi (0=kapali, 1=acik)
# RAG_ENABLED=1

# [OPSIYONEL] Egitim filtresi (0=kapali, 1=acik)
# EGITIM_FILTER_ENABLED=1
